{
  "manifest_version": 3,
  "name": "Keepsy",
  "version": "0.1.0",
  "description": "Save Everything. Find Anything.",
  "permissions": ["storage", "contextMenus"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": ["https://www.youtube.com/*", "https://i.ytimg.com/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Keepsy",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
